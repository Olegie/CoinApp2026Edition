<Window x:Class="CoinApp.Views.CoinView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CoinApp.Views"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks" xmlns:controls="clr-namespace:CoinApp.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="False"
        Background="{DynamicResource AppSurfaceBrush}"
        Icon="/Images/MainIconImg.jpg"
        Title="Coin App" Height="720" Width="1080" MinHeight="620" MinWidth="920">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="18" GlassFrameThickness="0" ResizeBorderThickness="8" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="18" MouseLeftButtonDown="Border_MouseLeftButtonDown" MouseDown="Border_MouseDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width = "250"/>
                <ColumnDefinition Width = "*"/>
            </Grid.ColumnDefinitions>

            <!--Left menu-->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Logo and name of app -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Додаю картинку -->
                    <Image Source="/Images/MainIconImg.jpg" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20,20,0,40" RenderTransformOrigin="-1.4,0.458" Height="36" Width="25"/>
                    <!-- Додаю текстову надпись -->
                    <TextBlock Text="Coin App" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" Margin="5,20,0,40"/>
                </Grid>

                <Border Grid.Row="1" Background="{DynamicResource AppPrimaryBrush}" CornerRadius="0 18 18 0">
                    <DockPanel>

                        <!--Menu titles and button-->
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0 30 0 0" HorizontalAlignment="Center">
                            <TextBlock Text="{DynamicResource Menu}" Foreground="White" FontSize="30" FontWeight="SemiBold" TextAlignment="Center"
             Margin="0 0 0 0"/>
                        </StackPanel>

                        <!--Menu separator-->
                        <Separator Margin="26 16 26 20" DockPanel.Dock="Top" Height="1" Background="#80FFFFFF"/>

                        <!--Menu buttons-->
                        <StackPanel DockPanel.Dock="Top">
                            <Button Style="{StaticResource menuButton}" Click="Refresh_Button_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Icon:PackIconMaterial Kind="Refresh" Style="{StaticResource menuButtonIcon}"/>
                                    <TextBlock Text="{DynamicResource RefreshPage}"/>
                                </StackPanel>
                            </Button>

                            <!--кнопки лівого меню-->
                            <controls:LeftMenuControl x:Name="LeftMenuControl"/>

                        </StackPanel>

                        <!--кнопка exit меню-->
                        <controls:LeftMenuExitButControls x:Name="LeftMenuExitButControls"/>

                    </DockPanel>
                </Border>
            </Grid>

            <!--Main section-->
            <Grid Grid.Column="1" Margin="30 20 20 20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <controls:TopContentControls x:Name="TopContentControls" Grid.Row="0"/>

                <!--Page title-->
                <TextBlock x:Name="CoinDetPageTitle" Text="{DynamicResource CoinDetPageTitle}" Grid.Row="1" FontSize="32" FontWeight="SemiBold" Margin="40,20,0,0" HorizontalAlignment="Left" Foreground="{DynamicResource AppTextBrush}" Grid.RowSpan="6"/>

                <!--Separator-->
                <Separator Height="1" Grid.Row="2" Background="{DynamicResource AppSeparatorBrush}" Margin="0 72 0 14"/>

                <Border Style="{StaticResource CoinBorder}" Grid.Row="4">
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width = "*"/>
                            <ColumnDefinition Width="300" MinWidth="280"/>
                        </Grid.ColumnDefinitions>

                        <!-- Панель завантаження -->
                        <Grid x:Name="LoadingPanel" Visibility="Collapsed" Background="Transparent" Opacity="0.8" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 115" Grid.ColumnSpan="2">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Vertical" Width="300" Height="150">
                                <!-- Повідомленя -->
                                <TextBlock Text="{DynamicResource LoadingPanel}" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource AppTextBrush}" Margin="0 0 0 14"/>
                                <ProgressBar IsIndeterminate="True" Style="{StaticResource CircularLoadingIndicator}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Container for the chart -->
                        <Grid x:Name="ChartContainer" Grid.Column="0" Margin="14 12 6 12">
                            <Grid.Resources>
                                <Style x:Key="historyRangeButton" TargetType="Button">
                                    <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="MinWidth" Value="46"/>
                                    <Setter Property="Height" Value="32"/>
                                    <Setter Property="Padding" Value="12 0"/>
                                    <Setter Property="Margin" Value="3 0"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="9">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AppTopHoverBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <Style TargetType="lvc:LineSeries">
                                    <Setter Property="StrokeThickness" Value="3"></Setter>
                                    <Setter Property="Stroke" Value="#4F6AF7"></Setter>
                                    <Setter Property="Fill" Value="#3B4F6AF7"></Setter>
                                    <Setter Property="PointGeometrySize" Value="8"></Setter>
                                    <Setter Property="PointForeground" Value="#F5F6FF"></Setter>
                                    <Setter Property="LineSmoothness" Value="0.65"></Setter>
                                </Style>
                                <Style TargetType="lvc:Axis">
                                    <Setter Property="ShowLabels" Value="True"></Setter>
                                    <Setter Property="IsEnabled" Value="True"></Setter>
                                    <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
                                </Style>
                                <Style TargetType="lvc:Separator">
                                    <Setter Property="StrokeThickness" Value="0.1"/>
                                    <Setter Property="Stroke" Value="#5e5b85"/>
                                </Style>
                            </Grid.Resources>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="4 2 4 12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Vertical">
                                    <TextBlock Text="{DynamicResource PriceHistoryTitle}"
                                               Foreground="{DynamicResource AppTextBrush}"
                                               FontSize="20"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding HistorySummary}"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               FontSize="12"
                                               Margin="0 3 0 0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12 0 0 0">
                                    <Button x:Name="Range7DButton" Style="{StaticResource historyRangeButton}" Content="7D" Tag="7D" Click="HistoryRange_Button_Click"/>
                                    <Button x:Name="Range1MButton" Style="{StaticResource historyRangeButton}" Content="1M" Tag="1M" Click="HistoryRange_Button_Click"/>
                                    <Button x:Name="Range3MButton" Style="{StaticResource historyRangeButton}" Content="3M" Tag="3M" Click="HistoryRange_Button_Click"/>
                                    <Button x:Name="Range1YButton" Style="{StaticResource historyRangeButton}" Content="1Y" Tag="1Y" Click="HistoryRange_Button_Click"/>
                                    <Button Style="{StaticResource topButton}" Click="ResetHistoryView_Button_Click" ToolTip="{DynamicResource ResetHistoryView}">
                                        <Icon:PackIconMaterial Kind="BackupRestore" Width="22" Height="22"/>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1" Background="{DynamicResource AppInputBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="18" Padding="10" ToolTip="{DynamicResource HistoryZoomHint}">
                                <Grid>
                                    <lvc:CartesianChart x:Name="HistoricalChart"
                                                        Series="{Binding SeriesCollection}"
                                                        Zoom="X"
                                                        Pan="X"
                                                        LegendLocation="None"
                                                        Margin="0">
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis Title="{Binding XAxis.Title}"
                                                      Labels="{Binding XAxis.Labels}"
                                                      Separator="{Binding XAxis.Separator}"/>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis Title="{Binding YAxis.Title}"
                                                      LabelFormatter="{Binding YAxis.LabelFormatter}" />
                                        </lvc:CartesianChart.AxisY>
                                    </lvc:CartesianChart>

                                    <ProgressBar x:Name="HistoryLoadingBar"
                                                 Visibility="Collapsed"
                                                 IsIndeterminate="True"
                                                 Style="{StaticResource CircularLoadingIndicator}"
                                                 Width="34"
                                                 Height="34"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Top"
                                                 Margin="0 12 14 0"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Grid.Column="1" x:Name="CoinDescriptionContainer" Margin="6 12 12 12">
                            <Grid.Resources>
                                <Style x:Key="metricLabelText" TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                                <Style x:Key="metricValueText" TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                                <Style x:Key="primaryActionButton" TargetType="Button">
                                    <Setter Property="Background" Value="{DynamicResource AppPrimaryBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AppMenuTextBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AppPrimaryHoverBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Height" Value="48"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="10">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AppPrimaryHoverBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Resources>

                            <Border Background="{DynamicResource AppCardBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0" LastChildFill="True">
                                        <Border DockPanel.Dock="Right"
                                                Background="{DynamicResource AppInputBrush}"
                                                BorderBrush="{DynamicResource AppBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="10 5"
                                                Margin="10 2 0 0">
                                            <TextBlock Text="{Binding Coin.Symbol}"
                                                       Foreground="{DynamicResource AppTextBrush}"
                                                       FontSize="12"
                                                       FontWeight="Bold"/>
                                        </Border>

                                        <StackPanel>
                                            <TextBlock Text="{Binding Coin.Name}"
                                                       Foreground="{DynamicResource AppTextBrush}"
                                                       FontWeight="Bold"
                                                       FontSize="24"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{DynamicResource CoinDetPageTitle}"
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       FontSize="12"
                                                       Margin="0 2 0 0"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <Border Grid.Row="1"
                                            Background="{DynamicResource AppInputBrush}"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="14"
                                            Margin="0 18 0 14">
                                        <StackPanel>
                                            <TextBlock x:Name="CoinPrice"
                                                       Text="{DynamicResource CoinPrice}"
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Coin.PriceUsd, StringFormat={}{0:F2} \$}"
                                                       Foreground="{DynamicResource AppTextBrush}"
                                                       FontSize="25"
                                                       FontWeight="Bold"
                                                       Margin="0 4 0 8"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Icon:PackIconMaterial Kind="TrendingUp"
                                                                       Foreground="{DynamicResource AppAccentBrush}"
                                                                       Width="16"
                                                                       Height="16"
                                                                       Margin="0 1 7 0"/>
                                                <TextBlock x:Name="CoinPriceCh"
                                                           Text="{DynamicResource CoinPriceCh}"
                                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                                           FontSize="12"
                                                           Margin="0 0 6 0"/>
                                                <TextBlock Text="{Binding Coin.ChangePercent24Hr, StringFormat={}{0:F2} \%}"
                                                           Foreground="{DynamicResource AppTextBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="42"/>
                                            <RowDefinition Height="42"/>
                                            <RowDefinition Height="42"/>
                                            <RowDefinition Height="42"/>
                                            <RowDefinition Height="42"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Icon:PackIconMaterial Kind="SwapHorizontal" Width="15" Height="15" Foreground="{DynamicResource AppMutedTextBrush}" Margin="0 0 8 0"/>
                                            <TextBlock x:Name="CoinSym" Text="{DynamicResource CoinSym}" Style="{StaticResource metricLabelText}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Coin.Symbol}" Style="{StaticResource metricValueText}"/>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Icon:PackIconMaterial Kind="Poll" Width="15" Height="15" Foreground="{DynamicResource AppMutedTextBrush}" Margin="0 0 8 0"/>
                                            <TextBlock x:Name="CoinVol" Text="{DynamicResource CoinVol}" Style="{StaticResource metricLabelText}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Coin.VolumeUsd24Hr, StringFormat={}{0:F2} \$}" Style="{StaticResource metricValueText}"/>

                                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Icon:PackIconMaterial Kind="Trophy" Width="15" Height="15" Foreground="{DynamicResource AppMutedTextBrush}" Margin="0 0 8 0"/>
                                            <TextBlock x:Name="CoinRank" Text="{DynamicResource CoinRank}" Style="{StaticResource metricLabelText}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Coin.Rank}" Style="{StaticResource metricValueText}"/>

                                        <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Icon:PackIconMaterial Kind="CurrencyUsd" Width="15" Height="15" Foreground="{DynamicResource AppMutedTextBrush}" Margin="0 0 8 0"/>
                                            <TextBlock x:Name="MarketCap" Text="{DynamicResource MarketCap}" Style="{StaticResource metricLabelText}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Coin.MarketCapUsd, StringFormat={}{0:F2} \$}" Style="{StaticResource metricValueText}"/>

                                        <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Icon:PackIconMaterial Kind="Database" Width="15" Height="15" Foreground="{DynamicResource AppMutedTextBrush}" Margin="0 0 8 0"/>
                                            <TextBlock x:Name="CoinSup" Text="{DynamicResource CoinSup}" Style="{StaticResource metricLabelText}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Coin.Supply, StringFormat={}{0:F2}}" Style="{StaticResource metricValueText}"/>
                                    </Grid>

                                    <Button Grid.Row="3"
                                            Style="{StaticResource primaryActionButton}"
                                            Margin="0 18 0 0"
                                            Click="Go_To_Market_Search_Page">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Icon:PackIconMaterial Kind="Cart" Width="18" Height="18" Margin="0 0 10 0"/>
                                            <TextBlock x:Name="Markets_for_purch" Text="{DynamicResource Markets_for_purch}"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>


                    </Grid>
                    
                </Border>
                
            </Grid>

        </Grid>
    </Border>

</Window>
