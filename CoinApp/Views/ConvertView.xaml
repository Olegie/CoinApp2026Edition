<Window x:Class="CoinApp.Views.ConvertView"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:local="clr-namespace:CoinApp"
         mc:Ignorable="d"
         xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
         xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks" xmlns:controls="clr-namespace:CoinApp.Controls"
         xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
         WindowStartupLocation="CenterScreen"
         WindowStyle="None"
         ResizeMode="CanResizeWithGrip"
         AllowsTransparency="False"
         Background="{DynamicResource AppSurfaceBrush}"
         Icon="/Images/MainIconImg.jpg"
         Title="Coin App" Height="720" Width="1080" MinHeight="620" MinWidth="920">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="18" GlassFrameThickness="0" ResizeBorderThickness="8" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="18" MouseLeftButtonDown="Border_MouseLeftButtonDown" MouseDown="Border_MouseDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width = "250"/>
                <ColumnDefinition Width = "*"/>
            </Grid.ColumnDefinitions>

            <!--Left menu-->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Logo and name of app -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Додаю картинку -->
                    <Image Source="/Images/MainIconImg.jpg" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20,20,0,40" RenderTransformOrigin="-1.4,0.458" Height="36" Width="25"/>
                    <!-- Додаю текстову надпись -->
                    <TextBlock Text="Coin App" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" Margin="5,20,0,40"/>
                </Grid>

                <Border Grid.Row="1" Background="{DynamicResource AppPrimaryBrush}" CornerRadius="0 18 18 0">
                    <DockPanel>

                        <!--Menu titles and button-->
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0 30 0 0" HorizontalAlignment="Center">
                            <TextBlock Text="{DynamicResource Menu}" Foreground="White" FontSize="30" FontWeight="SemiBold" TextAlignment="Center"
                         Margin="0 0 0 0"/>
                        </StackPanel>

                        <!--Menu separator-->
                        <Separator Margin="26 16 26 20" DockPanel.Dock="Top" Height="1" Background="#80FFFFFF"/>

                        <!--Menu buttons-->
                        <StackPanel DockPanel.Dock="Top">
                            <Button Style="{StaticResource menuButton}" Click="Refresh_Button_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Icon:PackIconMaterial Kind="Refresh" Style="{StaticResource menuButtonIcon}"/>
                                    <TextBlock Text="{DynamicResource RefreshPage}"/>
                                </StackPanel>
                            </Button>

                            <!--кнопки лівого меню-->
                            <controls:LeftMenuControl x:Name="LeftMenuControl"/>

                        </StackPanel>

                        <!--кнопка exit меню-->
                        <controls:LeftMenuExitButControls x:Name="LeftMenuExitButControls"/>

                    </DockPanel>
                </Border>
            </Grid>

            <!--Main section-->
            <Grid Grid.Column="1" Margin="30 20 20 20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <controls:TopContentControls x:Name="TopContentControls" Grid.Row="0"/>

                <!--Page title-->
                <TextBlock x:Name="ConverterPageTitle"  Text="{DynamicResource ConverterPageTitle}" Grid.Row="1" FontSize="32" FontWeight="SemiBold" Margin="40,20,0,0"
                HorizontalAlignment="Left" Foreground="{DynamicResource AppTextBrush}" Grid.RowSpan="6"/>

                <!--Separator-->
                <Separator Height="1" Grid.Row="2" Background="{DynamicResource AppSeparatorBrush}" Margin="0 72 0 14"/>

                <Border Grid.Row="3" Grid.RowSpan="4" Background="{DynamicResource AppPanelBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="18" Margin="10 12 10 10">
                    <Border x:Name="ConvBorder" VerticalAlignment="Center" Background="{DynamicResource AppCardBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Width="460" MaxWidth="560" Height="430" CornerRadius="18" Visibility="Visible">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="ConvertOneCurToAnotherTextBlock" Text="{DynamicResource ConvertOneCurToAnotherTextBlock}" Margin="0 34 0 8" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Row="0" FontWeight="Bold" FontSize="20" Foreground="{DynamicResource AppTextBrush}"/>
                            <TextBlock x:Name="AmountTextBlock" Text="{DynamicResource AmountTextBlock}" Margin="60 24 0 8" VerticalAlignment="Center" HorizontalAlignment="Left" Grid.Row="1" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AppMutedTextBrush}"/>
                            <Border Grid.Row="2" Background="{DynamicResource AppInputBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1.5"  Margin="55 2 55 10" Height="46" Width="340" CornerRadius="12">
                                <TextBox x:Name="InputAmountTextBox" Style="{StaticResource textboxConvert}"/>
                            </Border>
                            <StackPanel Grid.Row="3" Orientation="Vertical" Width="340" Height="96">
                                <DockPanel Width="340" Height="40">
                                    <TextBlock x:Name="FromTextBlock" Text="{DynamicResource FromTextBlock}" VerticalAlignment="Center" DockPanel.Dock="Left" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AppMutedTextBrush}"/>
                                    <TextBlock x:Name="ToTextBlock" Text="{DynamicResource ToTextBlock}" VerticalAlignment="Center" DockPanel.Dock="Right" HorizontalAlignment="Right" FontSize="14" FontWeight="SemiBold" Width="120" Foreground="{DynamicResource AppMutedTextBrush}"/>
                                </DockPanel>
                                <DockPanel>
                                    <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1.5" CornerRadius="12" Background="{DynamicResource AppInputBrush}" Height="44" Width="132">
                                        <ComboBox x:Name="CurrencyComboBox1" DockPanel.Dock="Left" Style="{StaticResource ComboBoxForConvert}"  ItemsSource="{Binding CurrencyNames}"
                                        SelectedItem="{Binding FirstSelectedCurrencyName, Mode=TwoWay}" GotFocus="ComboBox_GotFocus"
                                        LostFocus="ComboBox_LostFocus" />
                                    </Border>
                                    <Button Margin="8 0 0 0" Height="44" Background="{DynamicResource AppPrimaryBrush}" Foreground="White" BorderBrush="{DynamicResource AppPrimaryHoverBrush}" BorderThickness="1.5" Width="58" Click="Swap_Button_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <Icon:PackIconMaterial Kind="SwapHorizontal" Height="24" Width="24"/>
                                        </StackPanel>
                                    </Button>
                                    <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1.5" Width="132" HorizontalAlignment="Right" CornerRadius="12" Background="{DynamicResource AppInputBrush}" Height="44">
                                        <ComboBox x:Name="CurrencyComboBox2" DockPanel.Dock="Right" Style="{StaticResource ComboBoxForConvert}" HorizontalAlignment="Right"  ItemsSource="{Binding CurrencyNames}"
                                            SelectedItem="{Binding SecondSelectedCurrencyName, Mode=TwoWay}" GotFocus="ComboBox_GotFocus"
                                            LostFocus="ComboBox_LostFocus" />
                                    </Border>
                                </DockPanel>
                            </StackPanel>
                            <TextBox x:Name="ResultTextBox" Grid.Row="4" Style="{StaticResource TextBoxForResultOfConvert}" />
                            <Button x:Name="GetExchangeBut" Content="{DynamicResource GetExchangeBut}" Grid.Row="5" Style="{StaticResource PrimaryActionButton}" VerticalAlignment="Center" HorizontalAlignment="Center" Width="220" Margin="0 18 0 0" Click="GetExchangeRateButton_Click"/>
                        </Grid>
                    </Border>
                </Border>

                <!-- Панель завантаження -->
                <Grid x:Name="LoadingPanel" Visibility="Collapsed" Background="Transparent" Opacity="0.8" HorizontalAlignment="Center" VerticalAlignment="Top" Grid.Row="4" Margin="0 150">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Vertical" Width="300" Height="150">
                        <!-- Повідомленя -->
                        <TextBlock Text="{DynamicResource LoadingPanel}" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource AppTextBrush}" Margin="0 0 0 14"/>
                        <ProgressBar IsIndeterminate="True" Style="{StaticResource CircularLoadingIndicator}"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>
