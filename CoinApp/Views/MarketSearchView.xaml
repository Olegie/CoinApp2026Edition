<Window x:Class="CoinApp.Views.MarketSearchView"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:local="clr-namespace:CoinApp"
         mc:Ignorable="d"
         xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
         xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks" xmlns:controls="clr-namespace:CoinApp.Controls"
         xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
         WindowStartupLocation="CenterScreen"
         WindowStyle="None"
         ResizeMode="CanResizeWithGrip"
         AllowsTransparency="False"
         Background="{DynamicResource AppSurfaceBrush}"
         Icon="/Images/MainIconImg.jpg"
         Title="Coin App" Height="720" Width="1080" MinHeight="620" MinWidth="920">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="18" GlassFrameThickness="0" ResizeBorderThickness="8" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="18" MouseLeftButtonDown="Border_MouseLeftButtonDown" MouseDown="Border_MouseDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width = "250"/>
                <ColumnDefinition Width = "*"/>
            </Grid.ColumnDefinitions>

            <!--Left menu-->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Logo and name of app -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Додаю картинку -->
                    <Image Source="/Images/MainIconImg.jpg" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20,20,0,40" RenderTransformOrigin="-1.4,0.458" Height="36" Width="25"/>
                    <!-- Додаю текстову надпись -->
                    <TextBlock Text="Coin App" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" Margin="5,20,0,40"/>
                </Grid>

                <Border Grid.Row="1" Background="{DynamicResource AppPrimaryBrush}" CornerRadius="0 18 18 0">
                    <DockPanel>

                        <!--Menu titles and button-->
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0 30 0 0" HorizontalAlignment="Center">
                            <TextBlock Text="{DynamicResource Menu}" Foreground="White" FontSize="30" FontWeight="SemiBold" TextAlignment="Center"
                         Margin="0 0 0 0"/>
                        </StackPanel>

                        <!--Menu separator-->
                        <Separator Margin="26 16 26 20" DockPanel.Dock="Top" Height="1" Background="#80FFFFFF"/>

                        <!--Menu buttons-->
                        <StackPanel DockPanel.Dock="Top">
                            <Button Style="{StaticResource menuButton}" Click="Refresh_Button_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Icon:PackIconMaterial Kind="Refresh" Style="{StaticResource menuButtonIcon}"/>
                                    <TextBlock Text="{DynamicResource RefreshPage}"/>
                                </StackPanel>
                            </Button>

                            <!--кнопки лівого меню-->
                            <controls:LeftMenuControl x:Name="LeftMenuControl"/>

                        </StackPanel>

                        <!--кнопка exit меню-->
                        <controls:LeftMenuExitButControls x:Name="LeftMenuExitButControls"/>

                    </DockPanel>
                </Border>
            </Grid>

            <!--Main section-->
            <Grid Grid.Column="1" Margin="30 20 20 20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <controls:TopContentControls x:Name="TopContentControls" Grid.Row="0"/>

                <!--Page title-->
                <TextBlock x:Name="MarketSearchPageTitle"  Text="{DynamicResource MarketSearchPageTitle}" Grid.Row="1" FontSize="32" FontWeight="SemiBold" Margin="40,20,0,0"
                HorizontalAlignment="Left" Foreground="{DynamicResource AppTextBrush}" Grid.RowSpan="6"/>

                <!--Separator-->
                <Separator Height="1" Grid.Row="2" Background="{DynamicResource AppSeparatorBrush}" Margin="0 72 0 14"/>

                <Border Grid.Row="3" Background="{DynamicResource AppCardBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14 10" Margin="10 0 30 8">
                    <DockPanel LastChildFill="False">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                            <Icon:PackIconMaterial Kind="Magnify" Width="18" Height="18" Foreground="{DynamicResource AppAccentBrush}" Margin="0 1 10 0"/>
                            <TextBlock x:Name="Selected_Coin_Tb" Text="{DynamicResource Selected_Coin_Tb}" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}"/>
                            <TextBlock x:Name="CoinNameTextBlock" Text="{Binding SelectedCurrencyName}" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Margin="8 0 5 0" Foreground="{DynamicResource AppMutedTextBrush}"/>
                        </StackPanel>

                        <Border DockPanel.Dock="Right" Background="{DynamicResource AppInputBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1.5" CornerRadius="12" Width="240" Margin="18 0 0 0">
                        <ComboBox x:Name="CurrencyComboBox"
                          Width="206"
                          Height="34"
                          Style="{StaticResource AppComboBox}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Left"
                          IsEditable="True"
                          Margin="8,4,4,4"
                          BorderBrush="Transparent"
                          BorderThickness="0"
                          Text="Select coin"
                          ScrollViewer.VerticalScrollBarVisibility="Visible" 
                          GotFocus="CurrencyComboBox_GotFocus"
                          LostFocus="CurrencyComboBox_LostFocus" 
                          ItemsSource="{Binding CurrencyNames}"
                         SelectedItem="{Binding SelectedCurrencyName, Mode=TwoWay}"
                          />
                        </Border>
                    </DockPanel>
                </Border>
               


                <!--DataGrid-->
                <DataGrid x:Name="MarketsSearchDataGrid" ItemsSource="{Binding Markets}"
                  Style="{StaticResource CurrenciesAndMarketsDataGrid}" 
                  Grid.Row="4"
                  ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                  Visibility="Visible">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding RowNumber}" IsReadOnly="True" MinWidth="50" Width="auto"/>
                        <DataGridTextColumn Header="Exchange ID" Binding="{Binding DisplayExchangeId}" IsReadOnly="True" MinWidth="80" Width="auto"/>
                        <DataGridTextColumn Header="Base Symbol" Binding="{Binding DisplayBaseSymbol}" IsReadOnly="True" MinWidth="80" Width="*"/>
                        <DataGridTextColumn Header="Base ID" Binding="{Binding DisplayBaseId}" IsReadOnly="True" MinWidth="80" Width="auto"/>
                        <DataGridTextColumn Header="Quote ID" Binding="{Binding DisplayQuoteId}" IsReadOnly="True" MinWidth="65" Width="auto"/>
                        <DataGridTextColumn Header="Quote" Binding="{Binding DisplayQuoteSymbol}" IsReadOnly="True" MinWidth="65" Width="auto"/>
                        <DataGridTextColumn Header="Price" Binding="{Binding DisplayPriceUsd, StringFormat={}{0:F2} \$}"  IsReadOnly="True"  MinWidth="90"  Width="auto">
                            <DataGridTextColumn.ElementStyle>
                                <StaticResource ResourceKey="CenteredTextBlockStyle"/>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Volume (24 h)" Binding="{Binding DisplayVolumeUsd24Hr, StringFormat={}{0:F2} \$}"  IsReadOnly="True"  MinWidth="110"  Width="auto">
                            <DataGridTextColumn.ElementStyle>
                                <StaticResource ResourceKey="CenteredTextBlockStyle"/>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>

                </DataGrid>


                <!-- Панель завантаження -->
                <Grid x:Name="LoadingPanel" Visibility="Collapsed" Background="{DynamicResource AppSurfaceBrush}" Opacity="0.88" HorizontalAlignment="Center" VerticalAlignment="Top" Grid.Row="4" Margin="0 115">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Vertical" Width="300" Height="150">
                        <!-- Повідомленя -->
                        <TextBlock Text="{DynamicResource LoadingPanel}" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource AppTextBrush}" Margin="0 0 0 14"/>
                        <ProgressBar IsIndeterminate="True" Style="{StaticResource CircularLoadingIndicator}"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>
