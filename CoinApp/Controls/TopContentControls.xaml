<UserControl x:Class="CoinApp.Controls.TopContentControls"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CoinApp.Controls"
             xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="800">

    <Border Background="Transparent" ClipToBounds="False">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search TextBox with AutoComplete -->
            <Grid x:Name="SearchContainer" Grid.Column="0" MinWidth="220" MaxWidth="420" HorizontalAlignment="Left" Height="44" Margin="40 3 20 0">
                <Border Background="{DynamicResource AppInputBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1.5" CornerRadius="14">
                    <Grid>
                        <TextBox x:Name="searchTextBox"
                                 Text="{DynamicResource TabSeacrhCurrency}"
                                 Foreground="{DynamicResource AppMutedTextBrush}"
                                 FontSize="12"
                                 Margin="8 3 44 3"
                                 GotFocus="SearchTextBox_GotFocus"
                                 LostFocus="SearchTextBox_LostFocus"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="12 9"
                                 Style="{StaticResource textboxSearch}"
                                 TextChanged="SearchTextBox_TextChanged"/>
                    </Grid>
                </Border>
                <Button Style="{StaticResource topButton}"
                        Width="34"
                        Height="34"
                        Margin="0 0 5 0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right" Click="Go_To_Coin_Page_Click">
                    <Icon:PackIconMaterial Kind="Magnify" Width="20" Height="20" Foreground="{DynamicResource AppMutedTextBrush}" />
                </Button>
            </Grid>

            <!-- AutoComplete Popup -->
            <Popup x:Name="autoCompletePopup"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=searchTextBox}"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Slide">
                <Border Background="{DynamicResource AppPopupBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="2" CornerRadius="12">
                    <ListBox x:Name="autoCompleteListBox"
                             BorderThickness="0"
                             Background="{DynamicResource AppPopupBrush}"
                             Foreground="{DynamicResource AppTextBrush}"
                             SelectionChanged="AutoCompleteListBox_SelectionChanged"
                             MaxHeight="200">
                        <!-- Items will be populated programmatically -->
                    </ListBox>
                </Border>
            </Popup>

            <!--Top settings buttons-->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0 5 0 0" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button x:Name="ThemeButton" Style="{StaticResource topButton}" Click="Theme_Button_Click" ToolTip="{DynamicResource ThemeMenuTitle}">
                    <Icon:PackIconMaterial Kind="ThemeLightDark" Width="24" Height="24"/>
                </Button>

                <Button x:Name="LanguageButton" Style="{StaticResource topButton}" Click="Language_Button_Click" ToolTip="{DynamicResource LanguageMenuTitle}">
                    <Icon:PackIconMaterial Kind="Cog" Width="24" Height="24"/>
                </Button>

                <Button Style="{StaticResource topButton}" Click="Close_This_Window_Button_Click">
                    <Icon:PackIconMaterial Kind="Close" Width="24" Height="24"/>
                </Button>
            </StackPanel>

            <Popup x:Name="ThemePopup"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=ThemeButton}"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Background="{DynamicResource AppPopupBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="8" MinWidth="170">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource ThemeMenuTitle}" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" FontWeight="SemiBold" Margin="8 2 8 6"/>
                        <Button Style="{StaticResource popupMenuButton}" Tag="Light" Click="ThemeOption_Click">
                            <StackPanel Orientation="Horizontal">
                                <Icon:PackIconMaterial Kind="WhiteBalanceSunny" Width="16" Height="16" Margin="0 0 10 0"/>
                                <TextBlock Text="{DynamicResource LightTheme}"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource popupMenuButton}" Tag="Dark" Click="ThemeOption_Click">
                            <StackPanel Orientation="Horizontal">
                                <Icon:PackIconMaterial Kind="WeatherNight" Width="16" Height="16" Margin="0 0 10 0"/>
                                <TextBlock Text="{DynamicResource DarkTheme}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>

            <Popup x:Name="LanguagePopup"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=LanguageButton}"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Background="{DynamicResource AppPopupBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="8" MinWidth="170">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LanguageMenuTitle}" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" FontWeight="SemiBold" Margin="8 2 8 6"/>
                        <Button Style="{StaticResource popupMenuButton}" Tag="ENG" Click="LanguageOption_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="EN" Width="24" FontWeight="SemiBold"/>
                                <TextBlock Text="{DynamicResource EnglishLanguage}"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource popupMenuButton}" Tag="UKR" Click="LanguageOption_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="UK" Width="24" FontWeight="SemiBold"/>
                                <TextBlock Text="{DynamicResource UkrainianLanguage}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>

            <TextBlock x:Name="TabForSearchBox" Text="{DynamicResource TabForSearchBox}" Foreground="Transparent" Height="1" Width="1"/>
        </Grid>

    </Border>

</UserControl>
